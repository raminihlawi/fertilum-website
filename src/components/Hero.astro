---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;
---

<section style={{
  position: 'relative',
  overflow: 'hidden',
  height: isMobile ? 640 : 820,
  borderBottomLeftRadius: 40,
  borderBottomRightRadius: 40,
}}>
  <!-- Background gradient -->
  <div style={{
    position: 'absolute',
    inset: 0,
    background: `linear-gradient(180deg, ${T.ink} 0%, ${T.sageDeep} 40%, ${T.sage} 100%)`,
  }}></div>

  <!-- Content -->
  <div style={{
    position: 'relative',
    zIndex: 2,
    padding: isMobile ? '120px 20px 0' : '180px 72px 0',
    maxWidth: 1440,
    margin: '0 auto',
  }}>
    <div style={{
      display: 'inline-flex',
      alignItems: 'center',
      gap: 10,
      color: 'rgba(255,255,255,0.75)',
      marginBottom: isMobile ? 24 : 40,
      fontFamily: '"JetBrains Mono", monospace',
      fontSize: 12,
      letterSpacing: 0.6,
      textTransform: 'uppercase',
    }}>
      <span style={{
        width: 20,
        height: 1,
        background: 'rgba(255,255,255,0.5)',
      }}></span>
      {C.hero.eyebrow}
    </div>

    <h1 style={{
      fontFamily: '"Instrument Serif", serif',
      fontWeight: 400,
      fontSize: isMobile ? 52 : 128,
      lineHeight: 0.95,
      letterSpacing: isMobile ? -1.5 : -4,
      margin: 0,
      color: '#fff',
      maxWidth: 1100,
    }}>
      <span style={{ fontStyle: 'italic', color: T.sageSoft }}>
        {C.hero.title[0]}
      </span><br />
      {C.hero.title[1]}
    </h1>

    <p style={{
      marginTop: isMobile ? 24 : 40,
      maxWidth: 520,
      fontSize: isMobile ? 15 : 17,
      lineHeight: 1.55,
      color: 'rgba(255,255,255,0.78)',
    }}>
      {C.hero.sub}
    </p>

    <div style={{
      marginTop: isMobile ? 28 : 44,
      display: 'flex',
      gap: 12,
      flexWrap: 'wrap',
    }}>
      <button style={{
        padding: '12px 24px',
        borderRadius: 8,
        border: 'none',
        background: '#fff',
        color: T.ink,
        fontWeight: 500,
        fontSize: 14,
        cursor: 'pointer',
      }}>
        {C.nav.contact}
      </button>
    </div>
  </div>
</section>
