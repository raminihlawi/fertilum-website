---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';
import Placeholder from './Placeholder.astro';
import Button from './Button.astro';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;
---

<section style={{
  position: 'relative',
  overflow: 'hidden',
  height: isMobile ? 640 : 820,
  borderBottomLeftRadius: 40,
  borderBottomRightRadius: 40,
}}>
  <!-- Full-bleed background -->
  <div style={{
    position: 'absolute',
    inset: 0,
    background: `linear-gradient(180deg, ${T.ink} 0%, ${T.sageDeep} 40%, ${T.sage} 100%)`,
  }}>
    <!-- Abstract imagery treatment -->
    <div aria-hidden style={{
      position: 'absolute',
      inset: 0,
      background: `radial-gradient(ellipse at 80% 30%, rgba(244,217,201,0.35), transparent 55%),
                   radial-gradient(ellipse at 20% 90%, rgba(212,229,217,0.25), transparent 55%)`,
    }}></div>
    <div aria-hidden style={{
      position: 'absolute',
      inset: 0,
      backgroundImage: 'repeating-linear-gradient(45deg, transparent 0 30px, rgba(255,255,255,0.03) 30px 31px)',
    }}></div>

    <!-- Image card -->
    <div style={{
      position: 'absolute',
      right: isMobile ? '50%' : 80,
      bottom: isMobile ? 60 : 80,
      transform: isMobile ? 'translateX(50%)' : 'none',
      borderRadius: T.radiusLg,
      overflow: 'hidden',
      boxShadow: '0 30px 80px rgba(0,0,0,0.4)',
      border: '1px solid rgba(255,255,255,0.2)',
    }}>
      <Placeholder
        kind="clinical"
        label="Hero photo · clinical lab, morning light"
        width={isMobile ? 260 : 420}
        height={isMobile ? 160 : 260}
        radius={0}
      />
    </div>
  </div>

  <!-- Overlaid content -->
  <div style={{
    position: 'relative',
    zIndex: 2,
    padding: isMobile ? '120px 20px 0' : '180px 72px 0',
    maxWidth: 1440,
    margin: '0 auto',
  }}>
    <div style={{
      display: 'inline-flex',
      alignItems: 'center',
      gap: 10,
      color: 'rgba(255,255,255,0.75)',
      marginBottom: isMobile ? 24 : 40,
      fontFamily: '"JetBrains Mono", monospace',
      fontSize: 12,
      letterSpacing: 0.6,
      textTransform: 'uppercase',
    }}>
      <span style={{
        width: 20,
        height: 1,
        background: 'rgba(255,255,255,0.5)',
      }}></span>
      {C.hero.eyebrow}
    </div>

    <h1 style={{
      fontFamily: '"Instrument Serif", serif',
      fontWeight: 400,
      fontSize: isMobile ? 52 : 128,
      lineHeight: 0.95,
      letterSpacing: isMobile ? -1.5 : -4,
      margin: 0,
      color: '#fff',
      maxWidth: 1100,
    }}>
      <span style={{ fontStyle: 'italic', color: T.sageSoft }}>
        {C.hero.title[0]}
      </span><br />
      {C.hero.title[1]}
    </h1>

    <p style={{
      marginTop: isMobile ? 24 : 40,
      maxWidth: 520,
      fontSize: isMobile ? 15 : 17,
      lineHeight: 1.55,
      color: 'rgba(255,255,255,0.78)',
      margin: `${isMobile ? 24 : 40}px 0 0 0`,
    }}>
      {C.hero.sub}
    </p>

    <div style={{
      marginTop: isMobile ? 28 : 44,
      display: 'flex',
      gap: 12,
      flexWrap: 'wrap',
    }}>
      <Button tone="white" size="lg" icon="arrow">{C.nav.contact}</Button>
    </div>
  </div>

  <!-- Scroll hint -->
  {!isMobile && (
    <div style={{
      position: 'absolute',
      bottom: 28,
      left: 72,
      zIndex: 2,
      fontFamily: '"JetBrains Mono", monospace',
      fontSize: 11,
      letterSpacing: 0.6,
      textTransform: 'uppercase',
      color: 'rgba(255,255,255,0.55)',
      display: 'flex',
      alignItems: 'center',
      gap: 10,
    }}>
      <span>Scroll</span>
      <span style={{ width: 40, height: 1, background: 'rgba(255,255,255,0.4)' }} />
    </div>
  )}
</section>
