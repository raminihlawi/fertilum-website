---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;
---

<header style={{
  position: 'absolute',
  top: 0,
  left: 0,
  right: 0,
  zIndex: 10,
}}>
  <div style={{
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'space-between',
    padding: isMobile ? '18px 20px' : '28px 56px',
  }}>
    <div style={{
      fontFamily: '"Lobster", cursive',
      fontSize: isMobile ? 22 : 28,
      color: '#fff',
    }}>fertilum</div>

    {!isMobile && (
      <nav style={{
        display: 'flex',
        gap: 32,
        fontSize: 14,
        color: 'rgba(255,255,255,0.85)',
        background: 'rgba(255,255,255,0.08)',
        padding: '10px 22px',
        borderRadius: 999,
        border: '1px solid rgba(255,255,255,0.15)',
        backdropFilter: 'blur(14px)',
      }}>
        <span>{C.nav.clinicians}</span>
        <span>{C.nav.consumers}</span>
        <span>{C.nav.science}</span>
        <span>{C.nav.about}</span>
      </nav>
    )}

    <div style={{ display: 'flex', gap: 10, alignItems: 'center' }}>
      <div style={{
        display: 'flex',
        gap: 2,
        padding: 3,
        borderRadius: 999,
        background: 'rgba(255,255,255,0.1)',
        border: '1px solid rgba(255,255,255,0.15)',
        backdropFilter: 'blur(14px)',
      }}>
        {['EN', 'SV'].map((l) => (
          <span
            key={l}
            style={{
              padding: '4px 10px',
              borderRadius: 999,
              fontSize: 12,
              fontWeight: 500,
              background: l === C.lang ? '#fff' : 'transparent',
              color: l === C.lang ? T.ink : 'rgba(255,255,255,0.85)',
              cursor: 'pointer',
            }}
          >
            {l}
          </span>
        ))}
      </div>
      {!isMobile && (
        <button
          style={{
            padding: '8px 16px',
            borderRadius: 8,
            border: 'none',
            background: '#fff',
            color: T.ink,
            fontWeight: 500,
            fontSize: 14,
            cursor: 'pointer',
          }}
        >
          {C.nav.contact}
        </button>
      )}
    </div>
  </div>
</header>

<style>
  header {
    z-index: 10;
  }
</style>
