---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;
---

<section style={{
  padding: isMobile ? '40px 20px' : '80px 56px',
  background: T.bg,
}}>
  <div style={{ maxWidth: 1440, margin: '0 auto', textAlign: 'center' }}>
    <h2 style={{ fontSize: 32, margin: '0 0 20px 0' }}>{C.cta.title}</h2>
    <p style={{ fontSize: 18, color: T.inkMuted, margin: '0 0 40px 0' }}>{C.cta.sub}</p>
    <button style={{
      padding: '12px 24px',
      borderRadius: 8,
      border: 'none',
      background: T.sage,
      color: '#fff',
      fontWeight: 500,
      fontSize: 14,
      cursor: 'pointer',
    }}>
      {C.cta.primary}
    </button>
  </div>
</section>
