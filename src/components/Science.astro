---
import { COPY } from '../lib/copy';
import { TOKENS as T } from '../lib/tokens';

interface Props { lang: string; isMobile: boolean; }
const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
---

<section class="science">
  <div class="science__inner">
    <div class="science__header">
      <div class="science__eyebrow">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M6 3c3 2 5 4 5 7s-2 5-5 7M14 3c-3 2-5 4-5 7s2 5 5 7M7 6h6M7 10h6M7 14h6"/></svg>
        {C.science.eyebrow}
      </div>
      <h2 class="science__title">{C.science.title}</h2>
      <p class="science__sub">{C.science.body}</p>
    </div>
    <div class="science__grid">
      {C.science.papers.map((p, i) => (
        <div class="science__card">
          <span class="science__tag">{p.tag}</span>
          <div class="science__paper-title">{p.title}</div>
          <a href="#" class="science__link">
            Read study
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 10h12M12 6l4 4-4 4"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style define:vars={{ sage: T.sage, sageDeep: T.sageDeep, sageMist: T.sageMist, ink: T.ink, inkSoft: T.inkSoft, line: T.line, bgCard: T.bgCard, radiusLg: T.radiusLg, radiusPill: T.radiusPill }}>
  .science {
    padding: 140px 72px;
  }
  .science__inner { max-width: 1280px; margin: 0 auto; }
  .science__header { max-width: 720px; margin-bottom: 60px; }
  .science__eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 18px;
  }
  .science__title {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 52px;
    line-height: 1.05;
    letter-spacing: -1.4px;
    margin: 0 0 20px 0;
    color: var(--ink);
  }
  .science__sub {
    font-size: 17px;
    line-height: 1.6;
    color: var(--inkSoft);
    margin: 0;
  }
  .science__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .science__card {
    background: var(--bgCard);
    border: 1px solid var(--line);
    border-radius: var(--radiusLg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 220px;
  }
  .science__tag {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: var(--radiusPill);
    font-size: 12px;
    font-weight: 500;
    background: var(--sageMist);
    color: var(--sageDeep);
    align-self: flex-start;
  }
  .science__paper-title {
    font-family: 'Instrument Serif', serif;
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.2px;
    color: var(--ink);
    flex: 1;
  }
  .science__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--sage);
    font-weight: 500;
    text-decoration: none;
    transition: gap 160ms ease;
  }
  .science__link:hover { gap: 10px; }
</style>
