---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';
import Chip from './Chip.astro';
import Icon from './Icon.astro';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;
---

<section style={{
  padding: isMobile ? '60px 20px' : '140px 72px',
}}>
  <div style={{
    maxWidth: 1280,
    margin: '0 auto',
  }}>
    <div style={{
      maxWidth: 720,
      marginBottom: isMobile ? 36 : 60,
    }}>
      <div style={{
        display: 'flex',
        alignItems: 'center',
        gap: 8,
        marginBottom: 18,
      }}>
        <Icon name="dna" size={16} color={T.sage} />
        <span style={{
          fontFamily: '"JetBrains Mono", monospace',
          fontSize: 11,
          letterSpacing: 0.8,
          textTransform: 'uppercase',
          color: T.sage,
        }}>
          {C.science.eyebrow}
        </span>
      </div>
      <h2 style={{
        fontFamily: '"Instrument Serif", serif',
        fontWeight: 400,
        fontSize: isMobile ? 34 : 52,
        lineHeight: 1.05,
        letterSpacing: -1.4,
        margin: '0 0 20px 0',
      }}>
        {C.science.title}
      </h2>
      <p style={{
        fontSize: isMobile ? 15 : 17,
        lineHeight: 1.6,
        color: T.inkSoft,
        margin: 0,
      }}>
        {C.science.body}
      </p>
    </div>
    <div style={{
      display: 'grid',
      gap: isMobile ? 14 : 20,
      gridTemplateColumns: isMobile ? '1fr' : 'repeat(3, 1fr)',
    }}>
      {C.science.papers.map((p, i) => (
        <div
          key={i}
          style={{
            background: T.bgCard,
            border: `1px solid ${T.line}`,
            borderRadius: T.radiusLg,
            padding: isMobile ? 20 : 28,
            display: 'flex',
            flexDirection: 'column',
            gap: 14,
            minHeight: isMobile ? 'auto' : 220,
          }}
        >
          <Chip tone="sage">{p.tag}</Chip>
          <div style={{
            fontFamily: '"Instrument Serif", serif',
            fontSize: 20,
            lineHeight: 1.2,
            letterSpacing: -0.2,
            color: T.ink,
            flex: 1,
          }}>
            {p.title}
          </div>
          <div style={{
            display: 'inline-flex',
            alignItems: 'center',
            gap: 6,
            fontSize: 13,
            color: T.sage,
            fontWeight: 500,
            cursor: 'pointer',
          }}>
            Read study
            <Icon name="arrow" size={14} color={T.sage} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
