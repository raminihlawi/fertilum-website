---
import { COPY } from '../lib/copy';
import { TOKENS as T } from '../lib/tokens';

interface Props { lang: string; isMobile: boolean; }
const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const kinds = ['product', 'lifestyle', 'clinical'];
const palettes = {
  product:   { bg: T.cream,    stripe: 'rgba(180,140,90,0.2)' },
  lifestyle: { bg: T.peach,    stripe: 'rgba(217,163,137,0.35)' },
  clinical:  { bg: T.sageMist, stripe: 'rgba(74,138,123,0.18)' },
};
---

<section class="supps">
  <div class="supps__inner">
    <div class="supps__header">
      <div class="supps__eyebrow">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><rect x="3.5" y="7" width="13" height="6" rx="3"/><path d="M10 7v6"/></svg>
        {C.supplements.eyebrow}
      </div>
      <h2 class="supps__title">{C.supplements.title}</h2>
      <p class="supps__sub">{C.supplements.body}</p>
    </div>

    <div class="supps__grid">
      {C.supplements.items.map((it, i) => {
        const p = palettes[kinds[i]];
        return (
          <div class={`supps__item supps__item--${i}`}>
            <div class="supps__img" style={`background: ${p.bg}; background-image: repeating-linear-gradient(135deg, transparent 0 14px, ${p.stripe} 14px 15px)`}>
              <span class="supps__img-label">{it.name}</span>
            </div>
            <div class="supps__role">{it.role}</div>
            <div class="supps__name">{it.name}</div>
            <p class="supps__desc">{it.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style define:vars={{ bg: T.bg, cream: T.cream, ink: T.ink, inkSoft: T.inkSoft, inkMuted: T.inkMuted, peachDeep: T.peachDeep, sageDeep: T.sageDeep, radiusLg: T.radiusLg }}>
  .supps {
    padding: 140px 72px;
    background: linear-gradient(180deg, var(--bg) 0%, var(--cream) 100%);
  }
  .supps__inner { max-width: 1280px; margin: 0 auto; }
  .supps__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 56px;
  }
  .supps__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--peachDeep);
    margin-bottom: 20px;
  }
  .supps__title {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 56px;
    line-height: 1.02;
    letter-spacing: -1.5px;
    margin: 0 0 20px 0;
    color: var(--ink);
  }
  .supps__sub {
    font-size: 17px;
    line-height: 1.55;
    color: var(--inkSoft);
    margin: 0;
  }
  .supps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }
  .supps__item--1 { transform: translateY(40px); }
  .supps__img {
    height: 360px;
    border-radius: var(--radiusLg);
    position: relative;
    overflow: hidden;
    margin-bottom: 18px;
  }
  .supps__img-label {
    position: absolute;
    left: 16px; bottom: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--sageDeep);
    opacity: 0.75;
  }
  .supps__role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--inkMuted);
    margin-bottom: 6px;
  }
  .supps__name {
    font-family: 'Instrument Serif', serif;
    font-size: 26px;
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .supps__desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--inkSoft);
    margin: 0;
  }
</style>
