---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';
import Placeholder from './Placeholder.astro';
import Button from './Button.astro';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;

const items = [
  { ...C.hero.clinicianCard, side: 'clinician', kind: 'clinical', accent: T.sage },
  { ...C.hero.consumerCard, side: 'consumer', kind: 'lifestyle', accent: T.peachDeep },
];
---

<section style={{
  padding: isMobile ? '40px 20px' : '80px 72px',
  maxWidth: 1440,
  margin: '0 auto',
}}>
  <div style={{
    display: 'grid',
    gap: isMobile ? '14px' : '20px',
    gridTemplateColumns: isMobile ? '1fr' : '1fr 1fr',
  }}>
    {items.map((it, i) => (
      <div
        key={i}
        style={{
          background: T.bgCard,
          borderRadius: T.radiusXl,
          border: `1px solid ${T.line}`,
          padding: isMobile ? 20 : 28,
          display: 'grid',
          gap: 20,
          gridTemplateColumns: isMobile ? '1fr' : '1fr 0.9fr',
          alignItems: 'center',
          boxShadow: T.shadowSm,
        }}
      >
        <div>
          <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 14 }}>
            <span style={{ width: 6, height: 6, borderRadius: 999, background: it.accent }} />
            <span style={{
              fontFamily: '"JetBrains Mono", monospace',
              fontSize: 11,
              letterSpacing: 0.7,
              textTransform: 'uppercase',
              color: it.accent,
            }}>
              {it.kicker}
            </span>
          </div>
          <div style={{
            fontFamily: '"Instrument Serif", serif',
            fontWeight: 400,
            fontSize: isMobile ? 24 : 28,
            lineHeight: 1.1,
            letterSpacing: -0.5,
            marginBottom: 10,
          }}>
            {it.title}
          </div>
          <p style={{
            fontSize: 14,
            lineHeight: 1.55,
            color: T.inkSoft,
            margin: '0 0 18px 0',
          }}>
            {it.body}
          </p>
          <Button tone="ink" size="sm" icon="arrow">{it.cta}</Button>
        </div>
        <Placeholder
          kind={it.kind}
          label={it.side === 'clinician' ? 'Analyser close-up' : 'Couple portrait'}
          height={isMobile ? 160 : 200}
          radius={T.radiusLg}
        />
      </div>
    ))}
  </div>
</section>
