---
import { COPY } from '../lib/copy';
import { TOKENS as T } from '../lib/tokens';

interface Props { lang: string; isMobile: boolean; }
const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];

const items = [
  { ...C.hero.clinicianCard, kind: 'clinical', accent: T.sage },
  { ...C.hero.consumerCard, kind: 'lifestyle', accent: T.peachDeep },
];
---

<section class="split">
  <div class="split__grid">
    {items.map((it, i) => (
      <div class={`split__card split__card--${i}`}>
        <div class="split__text">
          <div class="split__kicker" style={`color: ${it.accent}`}>
            <span class="split__dot" style={`background: ${it.accent}`}></span>
            {it.kicker}
          </div>
          <div class="split__title">{it.title}</div>
          <p class="split__body">{it.body}</p>
          <a href="#contact" class="split__btn">
            {it.cta}
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 10h12M12 6l4 4-4 4"/></svg>
          </a>
        </div>
        <div class={`split__img split__img--${it.kind}`}>
          <span class="split__img-label">{i === 0 ? 'Analyser close-up' : 'Couple portrait'}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style define:vars={{ line: T.line, bgCard: T.bgCard, radiusXl: T.radiusXl, inkSoft: T.inkSoft, ink: T.ink, shadowSm: T.shadowSm, sageMist: T.sageMist, peach: T.peach, sageDeep: T.sageDeep, radiusLg: T.radiusLg }}>
  .split {
    padding: 80px 72px;
    max-width: 1440px;
    margin: 0 auto;
  }
  .split__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .split__card {
    background: var(--bgCard);
    border-radius: var(--radiusXl);
    border: 1px solid var(--line);
    padding: 28px;
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 20px;
    align-items: center;
    box-shadow: var(--shadowSm);
  }
  .split__kicker {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.7px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .split__dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .split__title {
    font-family: 'Instrument Serif', serif;
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .split__body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--inkSoft);
    margin: 0 0 18px 0;
  }
  .split__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 999px;
    background: var(--ink);
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    font-family: inherit;
    transition: transform 160ms ease;
  }
  .split__btn:hover { transform: translateY(-1px); }
  .split__img {
    height: 200px;
    border-radius: var(--radiusLg);
    position: relative;
    overflow: hidden;
  }
  .split__img--clinical {
    background: var(--sageMist);
    background-image: repeating-linear-gradient(135deg, transparent 0 14px, rgba(74,138,123,0.18) 14px 15px);
  }
  .split__img--lifestyle {
    background: var(--peach);
    background-image: repeating-linear-gradient(135deg, transparent 0 14px, rgba(217,163,137,0.35) 14px 15px);
  }
  .split__img-label {
    position: absolute;
    left: 16px; bottom: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--sageDeep);
    opacity: 0.75;
  }
</style>
