---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;
---

<footer style={{
  padding: isMobile ? '40px 20px' : '80px 56px',
  background: T.ink,
  color: '#fff',
}}>
  <div style={{ maxWidth: 1440, margin: '0 auto' }}>
    <p style={{ margin: 0, marginBottom: 40, fontSize: 18 }}>{C.footer.tagline}</p>
    <p style={{ fontSize: 14, color: 'rgba(255,255,255,0.6)', margin: 0 }}>{C.footer.legal}</p>
  </div>
</footer>
