---
import { COPY } from '../lib/copy';
import { TOKENS } from '../lib/tokens';

interface Props {
  lang: string;
  isMobile: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const C = COPY[lang];
const T = TOKENS;
---

<header class="nav">
  <div class="nav__container">
    <div class="nav__logo" style={{ fontSize: `${isMobile ? 22 : 28}px`, color: '#fff' }}>
      fertilum
    </div>

    {!isMobile && (
      <nav class="nav__menu">
        <span>{C.nav.clinicians}</span>
        <span>{C.nav.consumers}</span>
        <span>{C.nav.science}</span>
        <span>{C.nav.about}</span>
      </nav>
    )}

    <div class="nav__actions">
      <div class="nav__language-toggle">
        {['EN', 'SV'].map((l) => (
          <span
            key={l}
            class={`nav__lang-btn ${l === C.lang ? 'nav__lang-btn--active' : ''}`}
          >
            {l}
          </span>
        ))}
      </div>
      {!isMobile && (
        <button class="nav__cta">{C.nav.contact}</button>
      )}
    </div>
  </div>
</header>

<style define:vars={{ tokenSage: T.sage }}>
  .nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
  }

  .nav__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 56px;
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
  }

  .nav__logo {
    font-family: 'Lobster', cursive;
    font-weight: 400;
    letter-spacing: 0.2px;
  }

  .nav__menu {
    display: flex;
    gap: 32px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.08);
    padding: 10px 22px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(14px);
  }

  .nav__actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .nav__language-toggle {
    display: flex;
    gap: 2px;
    padding: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(14px);
  }

  .nav__lang-btn {
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 160ms ease;
    color: rgba(255, 255, 255, 0.85);
  }

  .nav__lang-btn--active {
    background: #fff;
    color: #1a2e2a;
  }

  .nav__cta {
    padding: 8px 16px;
    border-radius: 8px;
    border: none;
    background: #fff;
    color: #1a2e2a;
    font-weight: 500;
    font-size: 14px;
    cursor: pointer;
    font-family: inherit;
    transition: all 160ms ease;
  }

  .nav__cta:hover {
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .nav__container {
      padding: 18px 20px;
    }

    .nav__logo {
      font-size: 22px;
    }

    .nav__menu {
      display: none;
    }
  }
</style>
